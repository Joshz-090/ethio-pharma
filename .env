# Production Environment Variables for Render
# SECURITY
DEBUG=False
SECRET_KEY=django-insecure-production-key-please-change-this-in-render-dashboard
ALLOWED_HOSTS=ethio-pharma.onrender.com

# DATABASE - These will be provided by Render
# Make sure to set these in Render dashboard:
DB_NAME=ethio_pharma_db
DB_USER=ethio_pharma_user  
DB_PASSWORD=your-render-db-password
DB_HOST=your-render-db-host
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=https://ethio-pharma.onrender.com
